# Host path to the user-provided main.cpp.
# Relative paths are resolved from deploy/docker-compose.yml.
HOTFUZZ_MAIN_CPP=./examples/buffer_overflow.cpp

# Host directory where recorder artifacts are written.
HOTFUZZ_RECORDER_DIR=./output

# Optional: Debug, Release, RelWithDebInfo, MinSizeRel.
HOTFUZZ_BUILD_TYPE=RelWithDebInfo

# Recommended for memory-safety examples. Set to 0 for plain builds.
HOTFUZZ_ENABLE_SANITIZERS=1

# Match these to your host user on Linux to avoid root-owned artifacts.
# On Windows Docker Desktop these are usually harmless defaults.
HOTFUZZ_RUN_UID=1000
HOTFUZZ_RUN_GID=1000
